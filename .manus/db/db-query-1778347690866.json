  "query": "\nSELECT c.contract_no,\n  JSON_EXTRACT(c.raw_json, '$.num_installments') AS num_inst,\n  JSON_EXTRACT(c.raw_json, '$.installment_amount') AS inst_amt,\n  pt.external_id, pt.paid_at, pt.amount, pt.receipt_no\nFROM contracts c\nJOIN payment_transactions pt ON pt.contract_external_id = c.external_id AND pt.section = c.section\nWHERE c.contract_no = 'CT1024-SNI001-1086-01'\nORDER BY pt.paid_at, pt.external_id;\n",
