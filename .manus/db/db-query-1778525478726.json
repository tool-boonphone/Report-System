{
  "query": "\nSELECT \n  receipt_no,\n  contract_no,\n  CAST(amount AS DECIMAL(18,2)) AS pt_amount,\n  COALESCE(CAST(JSON_EXTRACT(raw_json, '$.principal_paid') AS DECIMAL(18,2)), 0) AS principal_paid,\n  COALESCE(CAST(JSON_EXTRACT(raw_json, '$.interest_paid') AS DECIMAL(18,2)), 0) AS interest_paid,\n  COALESCE(CAST(JSON_EXTRACT(raw_json, '$.fee_paid') AS DECIMAL(18,2)), 0) AS fee_paid,\n  COALESCE(CAST(JSON_EXTRACT(raw_json, '$.penalty_paid') AS DECIMAL(18,2)), 0) AS penalty_paid,\n  COALESCE(CAST(JSON_EXTRACT(raw_json, '$.unlock_fee_paid') AS DECIMAL(18,2)), 0) AS unlock_fee_paid,\n  COALESCE(CAST(JSON_EXTRACT(raw_json, '$.overpaid_amount') AS DECIMAL(18,2)), 0) AS overpaid_amount,\n  COALESCE(CAST(JSON_EXTRACT(raw_json, '$.discount_amount') AS DECIMAL(18,2)), 0) AS discount_amount,\n  COALESCE(CAST(JSON_EXTRACT(raw_json, '$.close_installment_amount') AS DECIMAL(18,2)), 0) AS close_installment_amount,\n  (\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.principal_paid') AS DECIMAL(18,2)), 0) +\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.interest_paid') AS DECIMAL(18,2)), 0) +\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.fee_paid') AS DECIMAL(18,2)), 0) +\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.penalty_paid') AS DECIMAL(18,2)), 0) +\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.unlock_fee_paid') AS DECIMAL(18,2)), 0) +\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.overpaid_amount') AS DECIMAL(18,2)), 0) -\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.discount_amount') AS DECIMAL(18,2)), 0)\n  ) AS sum_fields,\n  CAST(amount AS DECIMAL(18,2)) - (\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.principal_paid') AS DECIMAL(18,2)), 0) +\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.interest_paid') AS DECIMAL(18,2)), 0) +\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.fee_paid') AS DECIMAL(18,2)), 0) +\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.penalty_paid') AS DECIMAL(18,2)), 0) +\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.unlock_fee_paid') AS DECIMAL(18,2)), 0) +\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.overpaid_amount') AS DECIMAL(18,2)), 0) -\n    COALESCE(CAST(JSON_EXTRACT(raw_json, '$.discount_amount') AS DECIMAL(18,2)), 0)\n  ) AS diff,\n  JSON_EXTRACT(raw_json, '$.payment_type') AS payment_type,\n  JSON_EXTRACT(raw_json, '$.status') AS status\nFROM payment_transactions\nWHERE raw_json IS NOT NULL\n  AND amount IS NOT NULL\n  AND ABS(\n    CAST(amount AS DECIMAL(18,2)) - (\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.principal_paid') AS DECIMAL(18,2)), 0) +\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.interest_paid') AS DECIMAL(18,2)), 0) +\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.fee_paid') AS DECIMAL(18,2)), 0) +\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.penalty_paid') AS DECIMAL(18,2)), 0) +\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.unlock_fee_paid') AS DECIMAL(18,2)), 0) +\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.overpaid_amount') AS DECIMAL(18,2)), 0) -\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.discount_amount') AS DECIMAL(18,2)), 0)\n    )\n  ) >= 0.01\nORDER BY ABS(\n    CAST(amount AS DECIMAL(18,2)) - (\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.principal_paid') AS DECIMAL(18,2)), 0) +\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.interest_paid') AS DECIMAL(18,2)), 0) +\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.fee_paid') AS DECIMAL(18,2)), 0) +\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.penalty_paid') AS DECIMAL(18,2)), 0) +\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.unlock_fee_paid') AS DECIMAL(18,2)), 0) +\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.overpaid_amount') AS DECIMAL(18,2)), 0) -\n      COALESCE(CAST(JSON_EXTRACT(raw_json, '$.discount_amount') AS DECIMAL(18,2)), 0)\n    )\n  ) DESC;\n",
