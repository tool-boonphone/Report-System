{
  "query": "\nSELECT\n  SUBSTRING(paid_at, 9, 2) AS day_num,\n  SUM(CASE WHEN is_bad_debt_row = 1 THEN 0\n           WHEN is_close_row = 1 THEN 0\n           ELSE COALESCE(total_amount, 0) + COALESCE(overpaid, 0) END) AS kw,\n  SUM(CASE WHEN is_close_row = 1 AND is_bad_debt_row = 0\n           THEN COALESCE(total_amount, 0) ELSE 0 END) AS close_amount,\n  SUM(CASE WHEN is_bad_debt_row = 1\n           THEN COALESCE(bad_debt, 0) ELSE 0 END) AS sell\nFROM debt_collected_cache\nWHERE section = 'Fastfone365'\n  AND SUBSTRING(paid_at, 1, 7) = '2026-04'\n  AND paid_at IS NOT NULL AND paid_at != ''\nGROUP BY SUBSTRING(paid_at, 9, 2)\nORDER BY day_num ASC;\n",
