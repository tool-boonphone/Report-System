{
  "query": "\nSELECT\n  DATE(paid_at) AS paid_date,\n  SUM(CASE WHEN JSON_EXTRACT(raw_json, '$.source') = 'installment' THEN CAST(amount AS DECIMAL(18,2)) ELSE 0 END) AS sum_installment,\n  SUM(CASE WHEN JSON_EXTRACT(raw_json, '$.source') IS NULL THEN CAST(amount AS DECIMAL(18,2)) ELSE 0 END) AS sum_close_type,\n  SUM(CAST(amount AS DECIMAL(18,2))) AS sum_total\nFROM payment_transactions\nWHERE section = 'Fastfone365'\n  AND DATE(paid_at) BETWEEN '2026-04-01' AND '2026-04-30'\nGROUP BY DATE(paid_at)\nORDER BY paid_date ASC\nLIMIT 20;\n",
