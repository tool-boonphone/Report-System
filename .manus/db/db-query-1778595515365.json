  "query": "\n-- 252 rows ที่ debtDb.ts เห็น (TXRT receipt) แต่ runner.ts ไม่เห็น (amount = 0 หรือ external_id ขึ้นต้น pay-)\nSELECT \n  external_id,\n  receipt_no,\n  CAST(amount AS DECIMAL(18,2)) as amount,\n  contract_external_id,\n  paid_at,\n  updated_by,\n  created_at\nFROM payment_transactions\nWHERE section = 'Fastfone365'\n  AND NOT (external_id NOT LIKE 'pay-%' AND CAST(amount AS DECIMAL(18,2)) > 0)\n  AND (external_id REGEXP '^[0-9]+$' OR receipt_no REGEXP '^TXRT.*-[0-9]+$')\nLIMIT 20;\n",
