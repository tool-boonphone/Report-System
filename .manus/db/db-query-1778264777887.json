{
  "query": "\nSELECT\n  DATE(paid_at) AS paid_date,\n  SUM(CAST(amount AS DECIMAL(18,2))) AS sum_amount,\n  SUM(CAST(JSON_EXTRACT(raw_json, '$.close_installment_amount') AS DECIMAL(18,2))) AS sum_close,\n  SUM(CAST(JSON_EXTRACT(raw_json, '$.overpaid_amount') AS DECIMAL(18,2))) AS sum_overpaid,\n  SUM(CAST(JSON_EXTRACT(raw_json, '$.bad_debt_amount') AS DECIMAL(18,2))) AS sum_bad_debt,\n  SUM(CAST(amount AS DECIMAL(18,2))) \n    - SUM(CAST(JSON_EXTRACT(raw_json, '$.close_installment_amount') AS DECIMAL(18,2)))\n    - SUM(CAST(JSON_EXTRACT(raw_json, '$.overpaid_amount') AS DECIMAL(18,2))) AS net_amount\nFROM payment_transactions\nWHERE section = 'Fastfone365'\n  AND DATE(paid_at) BETWEEN '2026-04-01' AND '2026-04-30'\nGROUP BY DATE(paid_at)\nORDER BY paid_date ASC\nLIMIT 20;\n",
