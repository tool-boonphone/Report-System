  "query": "\nSELECT \n  DATE(pt.paid_at) AS day,\n  SUM(CAST(COALESCE(pt.amount, 0) AS DECIMAL(18,2))) AS total_amount,\n  COUNT(*) AS cnt\nFROM payment_transactions pt\nWHERE pt.section = 'Fastfone365'\n  AND JSON_EXTRACT(pt.raw_json, '$.source') IS NULL\n  AND pt.paid_at >= '2026-04-01'\n  AND pt.paid_at < '2026-05-01'\nGROUP BY DATE(pt.paid_at)\nORDER BY DATE(pt.paid_at) ASC\n",
