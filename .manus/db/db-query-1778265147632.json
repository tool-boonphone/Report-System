{
  "query": "\nSELECT\n  DATE(paid_at) AS paid_date,\n  SUM(CASE WHEN JSON_EXTRACT(raw_json, '$.source') IS NULL THEN CAST(amount AS DECIMAL(18,2)) ELSE 0 END) AS report_system_amount,\n  SUM(CASE WHEN JSON_EXTRACT(raw_json, '$.source') = 'installment' THEN CAST(amount AS DECIMAL(18,2)) ELSE 0 END) AS installment_amount,\n  SUM(CAST(amount AS DECIMAL(18,2))) AS total_amount,\n  SUM(CASE WHEN JSON_EXTRACT(raw_json, '$.source') IS NULL THEN 1 ELSE 0 END) AS close_rows,\n  SUM(CASE WHEN JSON_EXTRACT(raw_json, '$.source') = 'installment' THEN 1 ELSE 0 END) AS installment_rows\nFROM payment_transactions\nWHERE section = 'Fastfone365'\n  AND DATE(paid_at) BETWEEN '2026-04-01' AND '2026-04-30'\nGROUP BY DATE(paid_at)\nORDER BY paid_date ASC;\n",
