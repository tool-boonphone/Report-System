  "query": "\nSELECT pt.external_id, pt.paid_at, pt.amount, pt.receipt_no,\n  JSON_EXTRACT(pt.raw_json, '$.close_installment_amount') AS close_inst_amt,\n  JSON_EXTRACT(pt.raw_json, '$.principal_paid') AS principal,\n  JSON_EXTRACT(pt.raw_json, '$.interest_paid') AS interest,\n  JSON_EXTRACT(pt.raw_json, '$.fee_paid') AS fee,\n  JSON_EXTRACT(pt.raw_json, '$.overpaid_amount') AS overpaid,\n  JSON_EXTRACT(pt.raw_json, '$.discount_amount') AS discount,\n  JSON_EXTRACT(pt.raw_json, '$.bad_debt_amount') AS bad_debt,\n  pt.period_no, pt.sub_no\nFROM payment_transactions pt\nJOIN contracts c ON c.external_id = pt.contract_external_id AND c.section = pt.section\nWHERE c.contract_no = 'CT0225-KBI001-9274-01'\nORDER BY pt.paid_at, pt.external_id;\n",
