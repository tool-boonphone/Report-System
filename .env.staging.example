# Copy this file to .env.staging and fill in Render staging database URLs.
# Do not put live database URLs here.

PORT=3000
NODE_ENV=staging

# Staging databases must be separate Render PostgreSQL databases.
# The setup scripts reject URLs whose host/database name does not include
# staging, stage, test, or dev unless ALLOW_NON_STAGING_DATABASE=true is set.
BOONPHONE_DATABASE_URL=postgresql://user:password@host:port/boonphone_staging
FASTFONE_DATABASE_URL=postgresql://user:password@host:port/fastfone365_staging

JWT_SECRET=replace_with_a_long_random_staging_secret
VITE_APP_ID=staging
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Keep scheduler disabled for staging until you intentionally test API sync.
DISABLE_SCHEDULER=true

# Partner APIs are optional for seeded staging-data tests.
BOONPHONE_API_URL=
BOONPHONE_API_USERNAME=
BOONPHONE_API_PASSWORD=
FASTFONE_API_URL=
FASTFONE_API_USERNAME=
FASTFONE_API_PASSWORD=

MDM_API_KEY_BOONPHONE=
MDM_API_KEY_FASTFONE365=
