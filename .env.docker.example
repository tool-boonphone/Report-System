# Copy to .env for local Docker PostgreSQL on this machine.
#   cp .env.docker.example .env
#   docker compose up -d
#   ./scripts/restore-local-dbs.sh

PORT=3000

DATABASE_URL=postgresql://report:report@127.0.0.1:5432/boonphone_db?sslmode=disable
BOONPHONE_DATABASE_URL=postgresql://report:report@127.0.0.1:5432/boonphone_db?sslmode=disable
FASTFONE_DATABASE_URL=postgresql://report:report@127.0.0.1:5432/fastfone_db?sslmode=disable

JWT_SECRET=your_jwt_secret_here
VITE_APP_ID=your_app_id
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Disable scheduler and partner sync for local restore-based dev.
DISABLE_SCHEDULER=true
BOONPHONE_API_URL=
BOONPHONE_API_USERNAME=
BOONPHONE_API_PASSWORD=
FASTFONE_API_URL=
FASTFONE_API_USERNAME=
FASTFONE_API_PASSWORD=

MDM_API_KEY_BOONPHONE=
MDM_API_KEY_FASTFONE365=
